    "import pandas as pd\n",
    "\n",
    "# Konfiguration für Datenmenge (zwischen 0.0 und 1.0 für Bruchteil der Daten, oder absolute Zahl für Anzahl Zeilen)\n",
    "USE_FRACTION = True  # Set to False to use absolute row count instead of fraction\n",
    "DATA_FRACTION = 0.1  # Use 10% of the data (set between 0.0 and 1.0)\n",
    "MAX_ROWS = 10000     # Use this many rows if USE_FRACTION is False\n",
    "\n",
    "# Wenn die Datei direkt neben dem Notebook liegt:\n",
    "file_name = 'snapshots_2026-03-06.parquet' \n",
    "\n",
    "try:\n",
    "    # Lade die Daten\n",
    "    df_full = pd.read_parquet(file_name, engine = 'fastparquet')\n",
    "    print(f\"✅ Vollständige Datei geladen: {len(df_full)} Zeilen\")\n",
    "    \n",
    "    # Reduziere die Datenmenge basierend auf Konfiguration\n",
    "    if USE_FRACTION:\n",
    "        # Nimm einen Bruchteil der Daten (zufällig verteilt)\n",
    "        df = df_full.sample(frac=DATA_FRACTION, random_state=42)\n",
    "        print(f\"📊 Verwende {DATA_FRACTION*100}% der Daten: {len(df)} Zeilen (zufällige Stichprobe)\")\n",
    "    else:\n",
    "        # Nimm die ersten N Zeilen\n",
    "        df = df_full.head(MAX_ROWS)\n",
    "        print(f\"📊 Verwende erste {MAX_ROWS} Zeilen: {len(df)} Zeilen\")\n",
    "    \n",
    "    # Gib Speicher frei vom vollständigen Datensatz, falls nicht mehr benötigt\n",
    "    del df_full\n",
    "    \n",
    "    print(\"-\" * 30)\n",
    "    print(\"Spalten im Dataset:\", df.columns.tolist())\n",
    "    print(\"-\" * 30)\n",
    "    display(df.head()) # Zeigt die ersten 5 Zeilen schön formatiert an\n",
    "except Exception as e:\n",
    "    print(f\"❌ Fehler: {e}\")\n",
    "    print(\"Prüfe, ob der Dateiname exakt stimmt (inkl. .parquet)\")"
   ]
